# Telegram
BOT_TOKEN=123456:telegram_token
TELEGRAM_SECRET=long_random_secret_here
PUBLIC_URL=https://your-service.onrender.com
ADMIN_IDS=123456789
# Optional: restrict bot to specific group/chat IDs. For groups IDs are negative, e.g. -1001234567890
ALLOWED_CHAT_IDS=
# true = in allowed groups accept files from all users; false = only ADMIN_IDS can upload
ALLOW_GROUP_USERS=true
# false = do not spam group with “uploaded” messages, only log/save silently
SEND_ACK_IN_GROUP=false

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token
GOOGLE_SHEET_ID=google_sheet_id_here
GOOGLE_SHEET_TAB=Реестр

# Google Drive
GOOGLE_ROOT_FOLDER_NAME=Telegram Documents
# Optional: use an existing folder ID instead of searching/creating by name
GOOGLE_ROOT_FOLDER_ID=
# private = links work only for accounts with access; anyone_with_link = public by link
DRIVE_LINK_ACCESS=private

# Web panel
PANEL_LOGIN=admin
PANEL_PASSWORD=change_me

# Limits
TIMEZONE=Europe/Moscow
MAX_TELEGRAM_DOWNLOAD_MB=20

# Email with links only, no attachments
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_google_app_password
SMTP_FROM=your_gmail@gmail.com
EMAIL_TO=recipient@gmail.com
AUTO_EMAIL_ON_UPLOAD=false
